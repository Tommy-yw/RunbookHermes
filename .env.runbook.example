# RunbookHermes profile / model provider
HERMES_INFERENCE_PROVIDER=custom
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me

# Optional Runbook API model helper. Set RUNBOOK_MODEL_ENABLED=true only after you have a key.
RUNBOOK_MODEL_ENABLED=false
RUNBOOK_MODEL_PROVIDER=openai-compatible
RUNBOOK_MODEL_NAME=openrouter/auto
RUNBOOK_MODEL_BASE_URL=https://openrouter.ai/api/v1
RUNBOOK_MODEL_API_KEY=replace-me
RUNBOOK_MODEL_TEMPERATURE=0
RUNBOOK_MAX_TURNS=12

# Store
RUNBOOK_STORE_DIR=.runbook_hermes_store

# Backend switch
OBS_BACKEND=mock
DEPLOY_BACKEND=mock
TRACE_BACKEND=mock

# Prometheus
PROMETHEUS_BASE_URL=
PROMETHEUS_AUTH_TOKEN=
PROMETHEUS_TENANT=
PROMETHEUS_TIMEOUT_SECONDS=5

# Loki
LOKI_BASE_URL=
LOKI_AUTH_TOKEN=
LOKI_TENANT=
LOKI_TIMEOUT_SECONDS=5

# Trace
TRACE_BASE_URL=
TRACE_AUTH_TOKEN=
TRACE_PROVIDER_KIND=mock
TRACE_TIMEOUT_SECONDS=5

# Deploy / rollback
DEPLOY_API_BASE_URL=
DEPLOY_API_TOKEN=
DEPLOY_TIMEOUT_SECONDS=5
ROLLBACK_BACKEND_KIND=mock
ROLLOUT_APP_NAMESPACE=default

# Feishu / Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_CALLBACK_BASE_URL=
FEISHU_BOT_WEBHOOK_URL=
FEISHU_BOT_SECRET=

# WeCom / 企业微信
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CALLBACK_BASE_URL=

# Local payment demo / real observability mode.
# Keep these as mock until you start demo/payment_system/docker-compose.yml.
# OBS_BACKEND=real
# DEPLOY_BACKEND=demo_file
# TRACE_BACKEND=jaeger
# TRACE_PROVIDER_KIND=jaeger
# ROLLBACK_BACKEND_KIND=demo_file
# RUNBOOK_CONTROLLED_EXECUTION_ENABLED=true
# PROMETHEUS_BASE_URL=http://127.0.0.1:9090
# LOKI_BASE_URL=http://127.0.0.1:3100
# TRACE_BASE_URL=http://127.0.0.1:16686
# DEMO_DEPLOY_STATE_FILE=data/payment_demo/deployments.json
# DEMO_VERSION_FILE=data/payment_demo/runtime/payment-service-version.txt
# RUNBOOK_RECOVERY_VERIFY_WINDOW=2m
# RUNBOOK_RECOVERY_ERROR_RATE_THRESHOLD=0.02


# Controlled action executor shells
ACTION_EXECUTION_BACKEND=none
ACTION_EXECUTION_API_BASE_URL=
ACTION_EXECUTION_API_TOKEN=
ACTION_EXECUTION_TIMEOUT_SECONDS=5
